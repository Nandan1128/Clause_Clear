<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Global Action for Logout -->
    <action
        android:id="@+id/action_global_loginFragment"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />

    <!-- Auth Flow -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.clauseclear.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.clauseclear.ui.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Bottom Nav Destinations -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.clauseclear.ui.home.Home_fragment" />

    <fragment
        android:id="@+id/uploadFragment"
        android:name="com.example.clauseclear.ui.upload.Upload_Fragment">
        <action
            android:id="@+id/action_upload_to_processing"
            app:destination="@id/processingFragment" />
    </fragment>

    <fragment
        android:id="@+id/compareFragment"
        android:name="com.example.clauseclear.ui.compare.CompareFragment">
        <action
            android:id="@+id/action_compareFragment_to_sideBySideFragment"
            app:destination="@+id/sideBySideFragment"/>
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.clauseclear.ui.settings.SettingsFragment" />

    <!-- Internal Flow -->
    <fragment
        android:id="@+id/processingFragment"
        android:name="com.example.clauseclear.ui.processing.ProcessingFragment">
        <action
            android:id="@+id/action_processingFragment_to_summaryFragment"
            app:destination="@id/summaryFragment" />
    </fragment>

    <fragment
        android:id="@+id/summaryFragment"
        android:name="com.example.clauseclear.ui.summary.SummaryFragment">
        <action
            android:id="@+id/action_summaryFragment_to_clauseListFragment"
            app:destination="@id/clauseListFragment" />
    </fragment>

    <fragment
        android:id="@+id/clauseListFragment"
        android:name="com.example.clauseclear.ui.clause.ClauseListFragment">
        <action
            android:id="@+id/action_clauseListFragment_to_clauseDetailFragment"
            app:destination="@id/clauseDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/clauseDetailFragment"
        android:name="com.example.clauseclear.ui.clause.ClauseDetailFragment" />

    <fragment
        android:id="@+id/sideBySideFragment"
        android:name="com.example.clauseclear.ui.compare.SideBySideFragment" />

</navigation>
