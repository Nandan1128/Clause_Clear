<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_dark">

        <!-- Top App Bar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_dark"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            app:navigationIcon="@drawable/ic_back_arrow"
            app:navigationIconTint="@color/text_muted"
            app:title="@string/upload_document_title"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_muted"
            app:subtitle="PDF, DOC, or scan with camera" />

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <!-- Camera Scan Upload Zone -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/zone_camera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/transparent">

                    <!-- Dashed border achieved via background drawable -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:id="@+id/uploadPdf"
                        android:padding="40dp"
                        android:background="@drawable/bg_dashed_border">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/emoji_camera"
                            android:textSize="48sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan with Camera"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to open camera and scan"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:gravity="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- OR Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="or"
                        android:textSize="12sp"
                        android:textColor="@color/text_dim"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border" />

                </LinearLayout>

                <!-- Upload from Files Button -->
                <Button
                    android:id="@+id/btnUpload"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/upload_from_files_label"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/btn_secondary"
                    android:stateListAnimator="@null" />

                <!-- Tips Box -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface">

                    <!-- Left gold accent bar via background or inset drawable -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_left_accent_gold">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tips_title"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_gold"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#8226; " android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ensure good lighting, avoid shadows" android:textColor="@color/text_muted" android:textSize="12sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#8226; " android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Hold camera straight above document" android:textColor="@color/text_muted" android:textSize="12sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#8226; " android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="English language supported (MVP)" android:textColor="@color/text_muted" android:textSize="12sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&#8226; " android:textColor="@color/text_muted" android:textSize="12sp"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PDF files work best for accuracy" android:textColor="@color/text_muted" android:textSize="12sp"/>
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Privacy Notice -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface2">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="@string/privacy_notice_text"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:lineSpacingExtra="3dp" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>
</layout>