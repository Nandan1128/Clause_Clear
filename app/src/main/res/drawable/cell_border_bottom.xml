<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/cell_border_bottom.xml
    Draws a 1dp border ONLY on the BOTTOM edge.
    Usage: android:background="@drawable/cell_border_bottom"
    Applied to: Right column cells in the Side-by-Side comparison table
                where the cell is unchanged (green text) — needs bottom
                separator but NO right border (it's the last column).

    This is identical in structure to divider_bottom.xml.
    Having a separate file makes intent clearer in layout code
    and allows independent styling later (e.g. different border color).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Transparent background body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Layer 2: BOTTOM border (1dp horizontal line at the bottom edge) -->
    <item
        android:top="999dp"
        android:bottom="-1dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#2A2C38" />  <!-- @color/border -->
        </shape>
    </item>

</layer-list>